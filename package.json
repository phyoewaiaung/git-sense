  "author": "Phyo Wai Aung <phyowaiaung.pxyo@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@heyputer/puter.js": "^2.3.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "inquirer": "^13.4.2",
    "openai": "^6.36.0",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
