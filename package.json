{
  "name": "gitsense-cli",
  "version": "1.2.1",
  "description": "AI-powered Git commit message generator using Llama and GPT models",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "gs": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "git",
    "ai",
    "commit",
    "generator",
    "llama",
    "openai",
    "cli"
